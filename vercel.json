{
  "version": 2,
  "env": {
    "VITE_API_BASE_URL": "@vite_api_base_url",
    "VITE_WS_BASE_URL": "@vite_ws_base_url"
  },
  "builds": [
    {
      "src": "frontend",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "status": 404
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
